{
  "name": "@tansuasici/docsync",
  "version": "0.0.3",
  "description": "Transform GitHub markdown into docs-framework-compatible output. Write once in GFM, publish everywhere.",
  "type": "module",
  "bin": {
    "docsync": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "docs",
    "documentation",
    "markdown",
    "mdx",
    "fumadocs",
    "github",
    "gfm",
    "sync",
    "cli"
  ],
  "author": "tansuasici",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "c12": "4.0.0-beta.3",
    "citty": "^0.2.1",
    "fast-glob": "^3.3.3",
    "mdast-util-to-string": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.4.0",
    "@types/unist": "^3.0.3",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
